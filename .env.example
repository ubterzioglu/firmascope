# -------------------------------------------------------
# Coolify: these are BUILD ARGUMENTS (not runtime env).
# Set them under: Service → Build Arguments
# -------------------------------------------------------

# Supabase (frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# API (if applicable)
VITE_API_URL=https://api.firmascope.com

# -------------------------------------------------------
# Server-side only — NOT needed for the Docker image.
# Used by scripts/supabase CLI only.
# -------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# ADMIN_EMAIL=admin@firmascope.com
