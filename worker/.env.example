# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Service role key. NEVER expose this to the browser or commit it.
# Bypasses RLS so the worker can read/write the admin-only scraping tables.
SUPABASE_SERVICE_ROLE_KEY=

# Identifiable crawler User-Agent with a contact address (RFC 9309 expectation).
SCRAPE_USER_AGENT=FirmaScopeBot/0.1 (+contact: admin@firmascope.com; purpose: internal-company-indexing)

# Polling interval (ms) between checks for queued jobs when idle.
POLL_INTERVAL_MS=15000

# Politeness: max requests/minute per crawl and max concurrency.
MAX_REQUESTS_PER_MINUTE=60
MAX_CONCURRENCY=2

# Set RUN_ONCE=1 to process a single queued job then exit (GitHub Actions cron mode).
RUN_ONCE=
